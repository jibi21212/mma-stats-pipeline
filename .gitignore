# Build artifacts
scraper-go/ufcscraper.exe
*.exe
# Built Go scraper binary (regenerate: make build)
scraper-go/scraper
scraper-go/scraper-go
scraper-go/scraper-go.bin
# Rust TUI build output (also covered by tui-rs/.gitignore)
tui-rs/target/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# SQLite transient sidecar files (the data/ufc.db file itself IS committed)
data/*.db-wal
data/*.db-shm

# Generated ML artifacts (regenerate: python ml/run_all.py --min-fights 5 --k 6)
ml/outputs/

# Trained fight-outcome predictor (regenerate: cd ml && python predict.py --train)
ml/models/

# Local-only personal study notes (not shared)
notes/

# Local Claude Code guidance (kept out of version control)
CLAUDE.md
